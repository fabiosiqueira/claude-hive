#!/usr/bin/env bash
# SessionStart hook for Hive plugin — injects using-hive context into every session

set -euo pipefail

# Determine plugin root directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read using-hive skill content
using_hive_content=$(cat "${PLUGIN_ROOT}/skills/using-hive/SKILL.md" 2>&1 || echo "Error reading using-hive skill")

# Escape string for JSON embedding using bash parameter substitution
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

using_hive_escaped=$(escape_for_json "$using_hive_content")
session_context="<IMPORTANT>\nYou have Hive capabilities for multi-model parallel execution.\n\n**Below is the full content of your 'hive:using-hive' skill — your introduction to Hive. For all other skills, use the 'Skill' tool:**\n\n${using_hive_escaped}\n</IMPORTANT>"

# Output context injection as JSON
# Keep both shapes for compatibility:
# - additional_context for standard hooks
# - hookSpecificOutput.additionalContext for Claude hooks
cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
